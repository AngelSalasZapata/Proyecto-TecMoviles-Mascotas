<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/heroBackground"
            android:padding="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/donar_titulo"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/heroText" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Tu ayuda puede cambiar la vida de un animal"
                android:textSize="13sp"
                android:textColor="@color/heroText"
                android:alpha="0.85" />
        </LinearLayout>

        <!-- Form Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            style="@style/CardElevated"
            app:cardBackgroundColor="@color/cardBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Donation Type Label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tipo de donación"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary" />

                <RadioGroup
                    android:id="@+id/rgTipoDonacion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/outlineVariant"
                        app:cardBackgroundColor="@color/cardBackground">

                        <RadioButton
                            android:id="@+id/rbDinero"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/rb_dinero"
                            android:textSize="15sp"
                            android:textColor="@color/textPrimary"
                            android:checked="true"
                            android:padding="12dp"
                            android:buttonTint="@color/primary" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/outlineVariant"
                        app:cardBackgroundColor="@color/cardBackground">

                        <RadioButton
                            android:id="@+id/rbAlimento"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/rb_alimento"
                            android:textSize="15sp"
                            android:textColor="@color/textPrimary"
                            android:padding="12dp"
                            android:buttonTint="@color/primary" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/outlineVariant"
                        app:cardBackgroundColor="@color/cardBackground">

                        <RadioButton
                            android:id="@+id/rbMedicina"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/rb_medicina"
                            android:textSize="15sp"
                            android:textColor="@color/textPrimary"
                            android:padding="12dp"
                            android:buttonTint="@color/primary" />
                    </com.google.android.material.card.MaterialCardView>

                </RadioGroup>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="@color/dividerColor" />

                <!-- Amount Section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Monto de la donación"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/monto_hint"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/primary"
                    app:hintTextColor="@color/primary"
                    app:startIconDrawable="@drawable/ic_donar"
                    app:startIconTint="@color/primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMonto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Donate Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirmarDonacion"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:text="@string/btn_confirmar_donacion"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="28dp"
                    app:backgroundTint="@color/buttonDonate"
                    app:icon="@drawable/ic_donar"
                    app:iconGravity="textStart"
                    app:iconTint="@color/white" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
